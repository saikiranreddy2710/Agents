# ============================================================
# Agentic Browser System — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# LLM Provider (choose one or both)
# ------------------------------------------------------------

# Default LLM provider: "ollama" | "gemini" | "openai"
LLM_PROVIDER=ollama

# Ollama (local, free, supports LLaVA vision model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava                  # Vision model for screenshot analysis
OLLAMA_TEXT_MODEL=llama3            # Text-only model for fast decisions

# Google Gemini Flash (cheap cloud, no GPU needed)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI / OpenRouter compatible
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# ChromaDB (Vector Memory)
# ------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data    # Local persistence directory

# ------------------------------------------------------------
# LinkedIn Credentials
# ------------------------------------------------------------
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# LinkedIn session cookie (optional, avoids re-login)
LINKEDIN_SESSION_COOKIE=

# ------------------------------------------------------------
# Browser Configuration
# ------------------------------------------------------------

# Browser type: "chromium" | "firefox" | "webkit"
BROWSER_TYPE=chromium

# Run browser in headless mode (true = no UI, false = visible)
BROWSER_HEADLESS=false

# Browser pool size (parallel instances)
BROWSER_POOL_SIZE=3

# Slow down browser actions by N milliseconds (human-like)
BROWSER_SLOW_MO=50

# Browser viewport
BROWSER_WIDTH=1280
BROWSER_HEIGHT=800

# ------------------------------------------------------------
# Agent Behavior
# ------------------------------------------------------------

# Max iterations per agent task
AGENT_MAX_ITERATIONS=60

# Enable human-in-the-loop confirmation at finish
AGENT_HUMAN_CONFIRM=false

# Save successful subagents as skills
AGENT_SAVE_SKILLS=true

# Workspace directory for per-task isolation
AGENT_WORKSPACE_DIR=./workspace

# Skills library directory
AGENT_SKILLS_DIR=./skills

# ------------------------------------------------------------
# LinkedIn Automation Limits (anti-detection)
# ------------------------------------------------------------

# Max connection requests per day
LINKEDIN_MAX_CONNECTIONS_PER_DAY=20

# Max messages per day
LINKEDIN_MAX_MESSAGES_PER_DAY=10

# Min/max delay between actions (seconds)
LINKEDIN_MIN_DELAY=2
LINKEDIN_MAX_DELAY=8

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
